# OpenRouter (LLM provider for Hermes)
OPENROUTER_API_KEY=

# Encryption (32-byte hex string for AES-256-GCM)
BOT_TOKEN_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
