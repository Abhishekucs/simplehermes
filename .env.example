# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Blaxel
BL_API_KEY=
BL_WORKSPACE=
BL_REGION=us-pdx-1

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_ULTRA=

# Hermes Config (injected into user sandboxes)
HERMES_DOCKER_IMAGE=
HERMES_LLM_MODEL=global.anthropic.claude-sonnet-4-6

# AWS Bedrock (LLM provider for Hermes - use IAM user long-term keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Encryption (32-byte hex string for AES-256-GCM)
BOT_TOKEN_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
