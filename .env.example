# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Blaxel
BL_API_KEY=
BL_WORKSPACE=
BL_REGION=us-pdx-1

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PRODUCT_ID=

# Hermes Config (injected into user sandboxes)
HERMES_DOCKER_IMAGE=
